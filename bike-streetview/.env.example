# Google Maps Platform の APIキー（Maps JavaScript API を有効化したもの）
# このファイルを .env.local にコピーしてキーを記入する（.env.local はgit管理外）
# 必ず Google Cloud Console で予算アラートとクォータ制限を設定すること（仕様書 7章・10章）
VITE_GOOGLE_MAPS_API_KEY=

# Routes API用。ブラウザへ露出しないサーバー側キーを推奨
# ローカルテストでは未設定時にVITE_GOOGLE_MAPS_API_KEYを使用する
GOOGLE_ROUTES_API_KEY=
